{
  "name": "zk-aidshield",
  "private": true,
  "scripts": {
    "dev": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "seed": "npm --prefix packages/merkle-tools run seed",
    "test:merkle": "npm --prefix packages/merkle-tools test",
    "contracts:test": "cd contracts/disbursement && cargo test && cd ../verifier-groth16 && cargo test",
    "deploy:testnet": "./scripts/deploy-groth16.sh",
    "setup": "./scripts/setup.sh",
    "test": "npm --prefix apps/web test",
    "rotate:issuer": "node scripts/rotate-issuer-key.mjs",
    "check:production": "node scripts/check-production-readiness.mjs",
    "verify:proof": "node --import ./packages/merkle-tools/node_modules/tsx/dist/esm/index.mjs scripts/verify-known-proof.mjs",
    "secret:scan": "node scripts/secret-scan.mjs",
    "audit:all": "npm audit && npm --prefix apps/web audit && npm --prefix packages/merkle-tools audit && npm --prefix circuits/aidshield-groth16 audit"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^12.3.0"
  }
}
